

<mujoco model="PAR6_URDF">
  <compiler angle="radian" autolimits="true"  meshdir="assets"/>

  <option integrator="implicitfast"/>

  <!-- Default -->
  <default>
    <default class="Y">
      <joint range="-6.28319 6.28319" armature="0.001" damping="25.0" frictionloss="1.5"/>
      <position kp="500" forcerange="-300 300" ctrlrange="-6.28319 6.28319"/>
    </default>
    <default class="SSG48_gripper">
      <joint armature="0.1" damping="10.0" frictionloss="0"/>
      <position forcerange="-50 50" ctrlrange="-0.0235 0" kp="100"/>
    </default>
  </default>

  <asset>
    <mesh name="base_link" file="base_link.STL" scale="1 1 1"/>
    <mesh name="shoulder" file="shoulder.STL" scale="1 1 1"/>
    <mesh name="upper_arm" file="upper_arm.STL" scale="1 1 1"/>
    <mesh name="elbow" file="elbow.STL" scale="1 1 1"/>
    <mesh name="lower_arm" file="lower_arm.STL" scale="1 1 1"/>
    <mesh name="wrist" file="wrist.STL" scale="1 1 1"/>
    <mesh name="gripper" file="gripper_SSG48.STL" scale="1 1 1"/>
    <mesh name="jaw1" file="jaw1_SSG48.STL" scale="1 1 1"/>
    <mesh name="jaw2" file="jaw2_SSG48.STL" scale="1 1 1"/>
  </asset>

  <worldbody>
    <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="base_link"/>
    <body name="shoulder">
      <inertial pos="0.0065681 0.029094 0.099551" quat="0.438732 0.449118 -0.631911 0.454418" mass="1.993" diaginertia="0.00122723 0.00100741 0.000509712"/>
      <joint name="shoulder_JOINT" pos="0 0 0" axis="0 0 -1" class="Y"/>
      <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="shoulder"/>
      <body name="upper_arm" pos="0.023421 0 0.1105" quat="0.707105 -0.707108 0 0">
        <inertial pos="-0.0085493 -0.071342 0.041639" quat="0.419414 0.451905 -0.587174 0.5245" mass="1.332" diaginertia="0.00165491 0.00161199 0.0002696"/>
        <joint name="upper_arm_JOINT" pos="0 0 0" axis="0 0 1" class="Y"/>
        <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="upper_arm"/>
        <body name="elbow" pos="0 -0.18 0" quat="-2.59734e-06 0.707105 -0.707108 2.59735e-06">
          <inertial pos="0.015551 -0.019113 -0.0015332" quat="0.29143 0.634234 -0.265884 0.664922" mass="0.681" diaginertia="0.000816953 0.000689258 0.000454939"/>
          <joint name="elbow_JOINT" pos="0 0 0" axis="0 0 -1" class="Y"/>
          <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="elbow"/>
          <body name="lower_arm" pos="0.0435 0 0" quat="-2.59734e-06 -2.59735e-06 -0.707108 -0.707105">
            <inertial pos="0.00052734 -0.010166 -0.092593" quat="0.959861 -0.262793 -0.0146171 -0.0969154" mass="0.579" diaginertia="0.000384758 0.000361865 0.000214287"/>
            <joint name="lower_arm_JOINT" pos="0 0 0" axis="0 0 -1" class="Y"/>
            <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="lower_arm"/>
            <body name="wrist" pos="0 0 -0.177" quat="0.707105 -0.707108 0 0">
              <inertial pos="-1.5461e-06 -0.0031485 0.00019393" quat="0.721593 0.692318 0.000460117 -0.00048133" mass="0.523" diaginertia="0.00018083 0.000175719 0.000106091"/>
              <joint name="wrist_JOINT" pos="0 0 0" axis="0 0 1" class="Y"/>
              <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="wrist"/>
              <body name="gripper" quat="0.707105 0.707108 0 0">
                <inertial pos="-6.7987e-05 0.0001694 -0.077391" quat="0.464161 0.46546 -0.535128 0.530603" mass="0.374" diaginertia="0.00014808 0.000127124 5.86313e-05"/>
                <joint name="gripper_JOINT" pos="0 0 0" axis="0 0 -1" class="Y"/>
                <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="gripper"/>
                            <!-- Camera center -->
                <body name="camera_center" pos="0.0 -0.09 0.1">
                    <geom size="0.005 0.005 0.005" pos="0. 0. 0."
                        contype="0" conaffinity="0"
                        type="box" rgba="1.00 0.00 0.0 0" />
                    <camera name="egocentric" pos="0 0 0" xyaxes="-1 0 0 0 0 1" fovy="90" />
                </body>

                <body name="tcp_link" pos="0 -0.22 0">

                    <!-- Tool Center Point (main reference for control, IK, rewards) -->
                  <site name="tcp"
                        pos="0 0 0"
                        size="0.005"
                        rgba="1 0 0 1"/>


                  <geom type="capsule" fromto="0 0 -0.5 0 0 0.5" size="0.01" rgba="1.0 0.2 0.2 0.0" contype="0" conaffinity="0"/>
                  
                </body>

                <body name="jaw1" pos="0 0 -0.11745" quat="1.34924e-11 3.67321e-06 1 3.67321e-06">
                  <inertial pos="0.0033269 0.029197 -0.0097237" quat="0.427918 0.661892 -0.405093 0.463342" mass="0.02" diaginertia="4.64011e-06 3.93984e-06 1.21885e-06"/>
                  <joint name="jaw1_JOINT" pos="0 0 0" axis="0 -1 0" type="slide" range="-0.0235 0" class="SSG48_gripper"/>
                  <geom type="mesh"
                        mesh="jaw1"
                        rgba="0.29804 0.29804 0.29804 1"
                        friction="1.2 0.3 0.001"
                        solref="0.002 1"
                        solimp="0.9 0.95 0.001"/>

                </body>

                <body name="jaw2" pos="0 0 -0.11745" quat="1.34924e-11 3.67321e-06 1 3.67321e-06">
                  <inertial pos="-0.0033269 -0.029197 -0.0097237" quat="0.405093 0.463342 -0.427918 0.661892" mass="0.02" diaginertia="4.64011e-06 3.93984e-06 1.21885e-06"/>
                  <joint name="jaw2_JOINT" pos="0 0 0" axis="0 -1 0" type="slide" range="0 0.0235" class="SSG48_gripper"/>
                  <geom type="mesh"
                        mesh="jaw2"
                        rgba="0.29804 0.29804 0.29804 1"
                        friction="1.2 0.3 0.001"
                        solref="0.002 1"
                        solimp="0.9 0.95 0.001"/>

                </body>  
                
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>


  <!-- Exclude contact information -->
  <contact>
    <exclude body1="world" body2="shoulder"/>
  </contact>

  <!-- Gripper fingers are parallel -->
  <equality>
    <joint joint1="jaw2_JOINT" joint2="jaw1_JOINT" polycoef="0 -1 0 0 0"/>
  </equality>

  <!-- Define actuators -->
  <actuator>
    <position name="actuator_joint1" joint="shoulder_JOINT" class="Y"/>
    <position name="actuator_joint2" joint="upper_arm_JOINT" class="Y"/>
    <position name="actuator_joint3" joint="elbow_JOINT" class="Y"/>
    <position name="actuator_joint4" joint="lower_arm_JOINT" class="Y"/>
    <position name="actuator_joint5" joint="wrist_JOINT" class="Y"/>
    <position name="actuator_joint6" joint="gripper_JOINT" class="Y"/>

    <position name="actuator_rh_r1" joint="jaw1_JOINT" class="SSG48_gripper"/>


  </actuator>

</mujoco>



